{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "functions": {
    "api/alexa.js": {
      "memory": 512,
      "maxDuration": 15
    },
    "api/chat.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/alexa", "destination": "/api/alexa" },
    { "source": "/api/chat", "destination": "/api/chat" }
  ]
}
